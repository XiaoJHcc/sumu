{
  // Thin forwarders to the real scripts (scripts/ + native/). VSCode tasks just invoke
  // them with the right shell; all actual logic lives in the scripts themselves.
  "version": "2.0.0",
  "tasks": [
    {
      "label": "sumu: run (dev)",
      "detail": "Launch the daily-use player (scripts/play.py) with the venv interpreter.",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["scripts/play.py"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "sumu: build native",
      "detail": "Rebuild the native sumu_core.pyd via native/build.bat (needs VS2022 BuildTools).",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "native\\build.bat"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "sumu: apply patches",
      "detail": "Re-apply third-party runtime patches (ultralytics/mmengine) to .venv site-packages.",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/apply_patches.sh"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "sumu: build dist",
      "detail": "Full distributable pipeline: native build -> patches -> PyInstaller onedir -> stage weights -> smoke.",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy", "Bypass",
        "-File", "scripts/build_dist.ps1"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "sumu: build dist (no smoke)",
      "detail": "Same pipeline as 'sumu: build dist' but skips the smoke test (-SkipSmoke) -- dist\\sumu is built but not verified to start.",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy", "Bypass",
        "-File", "scripts/build_dist.ps1",
        "-SkipSmoke"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "sumu: build dist (fast)",
      "detail": "Iteration path for small sumu-only changes (-FastFreeze -SkipSmoke): skips PyInstaller COLLECT's full ~9-10GB _internal re-copy (only relinks sumu.exe + refreshes native pyd/ffmpeg DLLs) and skips the smoke test -- dist\\sumu is built but not verified to start. Requires a prior full 'sumu: build dist' and is unsafe if the dependency set (torch/cv2/tensorrt/mmengine) changed.",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy", "Bypass",
        "-File", "scripts/build_dist.ps1",
        "-FastFreeze",
        "-SkipSmoke"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    }
  ]
}
