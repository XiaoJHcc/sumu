# --- test footage (huge, not versioned) ---
test_video.mp4
test_video_4k.mp4
test_video_long.mp4
*.mp4

# --- downloaded build deps / tools (large, fetched not versioned) ---
third_party/
tools/
# ...except native/third_party/imgui/, which is VENDORED (source-in-tree, no fetch script /
# submodule -- see native/third_party/imgui/README.sumu.md). Re-include it in three steps:
# un-ignore the parent dir so git will descend, re-ignore anything else dropped alongside it
# (keeps the "fetched deps stay out" intent), then un-ignore the vendored imgui tree itself.
!native/third_party/
native/third_party/*
!native/third_party/imgui/

# --- native build ---
build/
native/build/
*.pyd
*.obj
*.lib
*.exp
*.pdb
*.ilk

# --- python ---
.venv/
__pycache__/
*.egg-info/
.python-version

# --- CUDA/TRT engine caches (arch-bound, never distributed) ---
*_sub_engines/
*.engine
model_weights/*.pt
model_weights/*.pth

# --- traces / measurement output ---
trace/
*_trace/
presentmon_*.csv
*.etl

# --- editor / OS ---
.vscode/
.idea/
.DS_Store

# --- build/run logs ---
*.log
*_log.txt

# --- copied runtime DLLs (fetched deps) ---
*.dll
